# Server
PORT=8000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/rxguard

# Auth
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=7d

# OCR Engine
OCR_ENGINE=easyocr
OCR_API_KEY=optional_if_external

# AI Interaction Model
MODEL_TYPE=xgboost
MODEL_PATH=./models/interaction-model.pkl

# FHIR Config
FHIR_VERSION=R4
FHIR_BASE_URL=https://fhirserver.example.com

# File Upload
MAX_FILE_SIZE=10485760

# CORS
CLIENT_URL=http://localhost:5173
